{
    "version": 2,
    "functions": {
        "api/index.ts": {
            "includeFiles": [
                "inventory.db",
                "node_modules/sql.js/dist/sql-wasm.wasm"
            ]
        }
    },
    "rewrites": [
        {
            "source": "/api/diag",
            "destination": "/api/diag.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}